rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Debe ser una cuenta real (Email/Password), no una sesión anónima.
    function esUsuarioReal() {
      return request.auth != null
             && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Rol de la cuenta actual en un centro dado ('admin' | 'lector' | null).
    // Si el perfil no existe, get() lanza y la regla deniega — comportamiento
    // seguro por defecto.
    function rolEnCentro(centroId) {
      let perfil = get(/databases/$(database)/documents/dialistock_usuarios/$(request.auth.uid)).data;
      return (centroId in perfil.centros) ? perfil.centros[centroId] : null;
    }

    function tieneAccesoACentro(centroId) {
      return esUsuarioReal() && rolEnCentro(centroId) != null;
    }

    function esAdminDeCentro(centroId) {
      return esUsuarioReal() && rolEnCentro(centroId) == 'admin';
    }

    // Independencia: ruta histórica — no se toca la estructura ya existente.
    match /dialistock_data/{docId} {
      allow read: if tieneAccesoACentro('independencia');
      allow write: if esAdminDeCentro('independencia')
                   && docId in ['main', 'invfis_progreso', 'invfis_historial'];
    }

    // Centros nuevos (Recoleta, Conchalí, Huechuraba, y los que se agreguen).
    match /centros/{centroId}/data/{docId} {
      allow read: if tieneAccesoACentro(centroId);
      allow write: if esAdminDeCentro(centroId)
                   && docId in ['main', 'invfis_progreso', 'invfis_historial'];
    }

    // Cada persona puede leer su propio perfil (para saber sus centros y
    // roles). Los accesos se asignan a mano desde la consola de Firebase.
    match /dialistock_usuarios/{uid} {
      allow read: if esUsuarioReal() && request.auth.uid == uid;
      allow write: if false;
    }

    // Todo lo demás queda bloqueado por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
